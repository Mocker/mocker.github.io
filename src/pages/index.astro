---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const selectedWork = (await getCollection('projects', ({ data }) => data.visibility !== 'hidden'))
  .sort((a, b) => a.data.order - b.data.order);

const capabilities = [
  {
    title: 'Architecture & systems',
    text: 'System boundaries, distributed services, data models, integration design, security, and pragmatic technology decisions.'
  },
  {
    title: 'Backend & cloud',
    text: 'Production APIs, financial data pipelines, Linux, AWS, Cloudflare, databases, CI/CD, fault tolerance, and operational tooling.'
  },
  {
    title: 'Product delivery',
    text: 'Turning ambiguous goals into shipped software through discovery, iterative planning, hands-on implementation, testing, and release.'
  },
  {
    title: 'Technical leadership',
    text: 'Cross-functional alignment, architecture guidance, mentoring, developer enablement, and clear communication with technical and business teams.'
  }
];
---

<BaseLayout>
  <section class="hero container" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">Senior Software Engineer · Software Architect</p>
      <h1 id="hero-title">I build reliable systems and help teams turn complex ideas into working software.</h1>
      <p class="hero-summary">
        I’m Ryan Guthrie, a hands-on engineer and architect with more than 20 years of experience across product development,
        distributed backend systems, cloud infrastructure, developer platforms, and technical leadership.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="/resume">View resume</a>
        <a class="btn-secondary" href="/assets/Ryan_Guthrie_Resume.pdf" target="_blank">Resume PDF <span aria-hidden="true">↗</span></a>
        <a class="text-link" href="mailto:ryan@ryanguthrie.com">ryan@ryanguthrie.com</a>
      </div>
      <div class="availability" aria-label="Location and work preference">
        <span>Eugene, Oregon</span>
        <span>Open to senior engineering and architecture roles</span>
      </div>
    </div>
    <aside class="hero-note" aria-label="Professional focus">
      <p class="eyebrow">What I bring</p>
      <p>Broad technical depth, careful system design, and the judgment to match architecture to the actual problem.</p>
      <dl>
        <div><dt>Experience</dt><dd>20+ years</dd></div>
        <div><dt>Perspective</dt><dd>Product to production</dd></div>
        <div><dt>Style</dt><dd>Hands-on and collaborative</dd></div>
      </dl>
    </aside>
  </section>

  <section id="about" class="section-shell about-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">About</p>
          <h2>Technical range with an architect’s view of the whole system.</h2>
        </div>
        <p class="section-intro">
          My career spans Linux operations, web and mobile development, financial data infrastructure, cloud platforms,
          and modern TypeScript products. I’m most useful where systems, product decisions, and delivery constraints meet.
        </p>
      </div>

      <div class="capability-grid">
        {capabilities.map((capability) => (
          <article>
            <h3>{capability.title}</h3>
            <p>{capability.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="work" class="section-shell container" aria-labelledby="work-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2 id="work-title">A concise view of what I design and deliver.</h2>
      </div>
      <p class="section-intro">
        These are intentionally brief. Employment work is described at a high level to respect company agreements;
        independent products and research will grow into deeper case studies as they mature.
      </p>
    </div>

    <div class="projects-grid">
      {selectedWork.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.summary}
          tags={project.data.tags}
          kind={project.data.kind}
          status={project.data.status}
          timeframe={project.data.timeframe}
        />
      ))}
    </div>
  </section>

  <section class="section-shell career-section">
    <div class="container career-grid">
      <div>
        <p class="eyebrow">Career</p>
        <h2>From Linux infrastructure to senior product engineering.</h2>
      </div>
      <div class="career-copy">
        <p>
          Most recently, I worked as a Senior Software Engineer at Earnest and Wizeline. Earlier, I spent seven years as
          Senior Software Architect at Paybook and more than a decade consulting across software development, infrastructure,
          security, and data systems.
        </p>
        <div class="career-actions">
          <a class="btn-primary" href="/resume">Explore career history</a>
          <a class="btn-secondary" href="https://www.linkedin.com/in/ryanguthrie/" target="_blank" rel="noopener noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="section-shell container contact-section" aria-labelledby="contact-title">
    <div class="contact-panel">
      <p class="eyebrow">Contact</p>
      <h2 id="contact-title">Let’s talk about the system you need to build—or the one you need to make better.</h2>
      <p>I’m available for senior software engineering, architecture, and technical leadership opportunities.</p>
      <a class="btn-primary" href="mailto:ryan@ryanguthrie.com">Email Ryan</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: min(760px, calc(100vh - var(--nav-height)));
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.7fr);
    gap: clamp(3rem, 8vw, 7rem);
    align-items: center;
    padding-block: clamp(5rem, 10vw, 8.5rem);
  }

  .hero h1 {
    max-width: 900px;
    margin-top: 1rem;
    font-size: clamp(3rem, 6.5vw, 5.7rem);
    letter-spacing: -0.055em;
  }

  .hero-summary {
    max-width: 760px;
    margin-top: 1.75rem;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.75;
  }

  .hero-actions,
  .availability,
  .career-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-actions {
    gap: 0.85rem;
    margin-top: 2.1rem;
  }

  .hero-actions .text-link {
    margin-left: 0.4rem;
  }

  .availability {
    gap: 0.6rem 1.5rem;
    margin-top: 2.2rem;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .availability span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .availability span::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .hero-note {
    padding-left: 1.75rem;
    border-left: 1px solid var(--line-strong);
  }

  .hero-note > p:nth-child(2) {
    margin-top: 0.9rem;
    font-size: 1.05rem;
  }

  dl {
    margin: 2rem 0 0;
  }

  dl div {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 1rem;
    padding-block: 0.8rem;
    border-top: 1px solid var(--line);
  }

  dt {
    color: var(--muted);
    font-size: 0.82rem;
  }

  dd {
    margin: 0;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 650;
  }

  .about-section,
  .career-section {
    border-block: 1px solid var(--line);
    background: rgba(16, 25, 35, 0.46);
  }

  .capability-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-block: 1px solid var(--line);
  }

  .capability-grid article {
    padding: 1.6rem 1.4rem 1.6rem 0;
  }

  .capability-grid article + article {
    padding-left: 1.4rem;
    border-left: 1px solid var(--line);
  }

  .capability-grid h3 {
    font-size: 1.05rem;
  }

  .capability-grid p {
    margin-top: 0.75rem;
    font-size: 0.92rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .career-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 7vw, 6rem);
  }

  .career-grid h2,
  .contact-panel h2 {
    margin-top: 0.7rem;
    font-size: clamp(2rem, 4vw, 3.25rem);
    letter-spacing: -0.04em;
  }

  .career-copy > p {
    font-size: 1.08rem;
  }

  .career-actions {
    gap: 0.8rem;
    margin-top: 1.8rem;
  }

  .contact-section {
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .contact-panel {
    max-width: 900px;
  }

  .contact-panel p:not(.eyebrow) {
    margin-top: 1.25rem;
    font-size: 1.08rem;
  }

  .contact-panel .btn-primary {
    margin-top: 1.8rem;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-note {
      max-width: 580px;
    }

    .capability-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .capability-grid article:nth-child(3) {
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid var(--line);
    }

    .capability-grid article:nth-child(4) {
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 700px) {
    .projects-grid,
    .career-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .hero {
      padding-block: 4rem 5rem;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions .text-link {
      justify-content: center;
      margin: 0.3rem 0 0;
    }

    .capability-grid {
      grid-template-columns: 1fr;
    }

    .capability-grid article,
    .capability-grid article + article,
    .capability-grid article:nth-child(3) {
      padding: 1.25rem 0;
      border-left: 0;
      border-top: 1px solid var(--line);
    }
  }
</style>
