---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const resumeEntry = await getEntry('resume', 'experience');
const resumeData = resumeEntry?.data;

// Use featured skills for the homepage cloud to keep it sharp and concise!
const displaySkills = resumeData?.skills.featured || [
  "Solution & System Architecture",
  "Engineering Leadership",
  "Cloud & Edge Infrastructure",
  "TypeScript / JavaScript",
  "Golang Backend Systems",
  "AI Agentic Workflows",
  "Linux Server Security",
  "PostgreSQL / Supabase"
];
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="hero container" aria-labelledby="hero-title">
    <div class="hero-content">
      <p class="greeting">Hi, my name is</p>
      <h1 id="hero-title" class="name-title">Ryan Guthrie<span class="accent">.</span></h1>
      <h2 class="role-title">Staff Software Architect &amp; Engineering Lead.</h2>
      <p class="hero-desc">
        With <strong class="text-highlight">20+ years of engineering leadership</strong>, I specialize in architecting horizontally scalable systems, 
        cloud/edge infrastructure, and AI agentic workflows—while guiding cross-functional teams from first-principles 
        planning to reliable production release. I love turning complex organizational requirements into clean, 
        low-maintenance software architectures that just work.
      </p>
      <div class="hero-ctas">
        <a href="#projects" class="btn-primary">Explore Featured Work</a>
        <a href="/resume" class="btn-secondary">View 20-Year Resume</a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section container" aria-labelledby="about-title">
    <div class="section-heading">
      <h2 id="about-title" class="section-title"><span class="section-num">01.</span> About Me</h2>
      <div class="heading-line"></div>
    </div>
    
    <div class="about-grid">
      <div class="about-text glass-card">
        <p>
          Hello! I'm Ryan, a Staff Software Architect and Engineering Lead based in <strong class="text-white">Eugene, Oregon</strong>. For more than two decades, 
          I have been designing and building across the software stack—from Linux server security hardening and VoIP network automation 
          to architecting high-throughput cloud infrastructure and modern AI agentic pipelines.
        </p>
        <p>
          My true strength lies in my ability to <strong class="text-highlight">plan, architect, and lead complex engineering initiatives</strong> across organizations without ego. 
          Career highlights include leading multi-team technical projects at <strong class="text-white">Earnest</strong> and <strong class="text-white">Wizeline</strong>, as well as spending 7 years 
          at <strong class="text-white">Paybook</strong>, where I <em class="text-cyan">designed and built solo</em> the first horizontal-scaling backend platform aggregating financial 
          data across banks in Mexico, LatAm, US, and Crypto (<em class="text-cyan">like Plaid before there was Plaid</em>).
        </p>
        <p>
          I evaluate systems through <strong class="text-cyan">first-principles logic</strong>, advocating for <strong class="text-cyan">low-energy maintenance</strong>, <strong class="text-cyan">zero-bloat web architecture</strong>, 
          and <strong class="text-cyan">data independence</strong> (such as contributing to decentralized protocols like Nostr). While I guide high-level architecture, 
          I remain deeply hands-on. Here is my featured technical arsenal:
        </p>
      </div>
      
      <div class="skills-cloud glass-card">
        <h3 class="skills-title">Featured Technical Arsenal</h3>
        <p class="skills-subtitle">Top modern weapons &amp; architectural strengths</p>
        <div class="tags-wrapper">
          {displaySkills.map((skill) => (
            <span class="tag-pill skill-tag">{skill}</span>
          ))}
        </div>
        <div class="skills-footer">
          <a href="/resume" class="vault-link">View complete 20-year technical vault →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="section container" aria-labelledby="projects-title">
    <div class="section-heading">
      <h2 id="projects-title" class="section-title"><span class="section-num">02.</span> Featured Architecture &amp; Projects</h2>
      <div class="heading-line"></div>
    </div>
    
    <div class="projects-grid">
      {featuredProjects.map((project) => (
        <ProjectCard 
          title={project.data.title}
          description={project.data.description || project.data.summary}
          tags={project.data.tags}
          slug={project.id}
          liveUrl={project.data.liveUrl}
          githubUrl={project.data.githubUrl}
          featured={project.data.featured}
        />
      ))}
    </div>
  </section>

  <!-- Resume Summary Section -->
  <section id="resume" class="section container" aria-labelledby="resume-title">
    <div class="section-heading">
      <h2 id="resume-title" class="section-title"><span class="section-num">03.</span> Leadership &amp; Career History</h2>
      <div class="heading-line"></div>
    </div>
    
    <div class="resume-card glass-card">
      <div class="resume-header">
        <div>
          <h3 class="resume-role">20+ Years of Systems Architecture &amp; Technical Leadership</h3>
          <p class="resume-meta">Earnest &middot; Wizeline &middot; Paybook &middot; Principal Consulting &middot; Linux SysAdmin</p>
        </div>
        <div class="resume-actions">
          <a href="/resume" class="btn-primary resume-btn">Explore Full Career History</a>
          <a href="/assets/Ryan_Guthrie_Resume.pdf" download="Ryan_Guthrie_Resume.pdf" class="btn-secondary">Download PDF</a>
        </div>
      </div>
      <p class="resume-summary">
        Proven track record of guiding software architecture from first-principles concepts through reliable edge deployment. 
        Adept at leading cross-functional initiatives, horizontal backend scaling, cloud infrastructures (AWS/Cloudflare), 
        high-throughput Golang/TS systems, and integrating agentic AI tooling into production workflows.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section container contact-section" aria-labelledby="contact-title">
    <div class="contact-card glass-card">
      <p class="contact-sub"><span class="section-num">04.</span> What's Next?</p>
      <h2 id="contact-title" class="contact-title">Get In Touch</h2>
      <p class="contact-desc">
        Whether you have a question about my architectural approach, want to discuss a staff/lead engineering leadership role, 
        or just want to talk systems from first principles, my inbox is open. I'll get back to you soon!
      </p>
      <a href="mailto:ryan@ryanguthrie.com" class="btn-primary contact-btn">Say Hello</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    padding-top: 2rem;
    padding-bottom: 6rem;
  }

  .hero-content {
    max-width: 850px;
  }

  .greeting {
    font-family: var(--font-display);
    color: var(--accent-cyan);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .name-title {
    color: #ffffff;
    margin-bottom: 0.5rem;
  }

  .role-title {
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    max-width: 680px;
    font-size: 1.2rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .text-highlight {
    color: #ffffff;
    font-weight: 600;
    background: rgba(19, 200, 236, 0.12);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    border: 1px solid rgba(19, 200, 236, 0.25);
    display: inline-block;
  }

  .text-white {
    color: #ffffff;
    font-weight: 600;
  }

  .text-cyan {
    color: var(--accent-cyan);
    font-weight: 600;
    font-style: normal;
  }

  .hero-ctas {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Section Headings */
  .section {
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    white-space: nowrap;
    margin-bottom: 0;
  }

  .section-num {
    color: var(--accent-cyan);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 500;
    margin-right: 0.5rem;
  }

  .heading-line {
    width: 100%;
    height: 1px;
    background: var(--glass-border);
    max-width: 300px;
  }

  /* About Section */
  .about-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 2rem;
    align-items: start;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  .skills-cloud {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skills-title {
    font-size: 1.3rem;
    color: #ffffff;
    margin: 0;
  }

  .skills-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .tags-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .skill-tag {
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
  }

  .skills-footer {
    border-top: 1px solid var(--glass-border);
    padding-top: 1rem;
  }

  .vault-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--accent-cyan);
  }

  .vault-link:hover {
    color: var(--accent-teal);
  }

  /* Projects Section */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  /* Resume Section */
  .resume-card {
    padding: 2.5rem;
  }

  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--glass-border);
  }

  .resume-role {
    font-size: 1.5rem;
    color: #ffffff;
    margin-bottom: 0.5rem;
  }

  .resume-meta {
    color: var(--accent-cyan);
    font-weight: 500;
    margin: 0;
  }

  .resume-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .resume-summary {
    font-size: 1.1rem;
    margin: 0;
  }

  /* Contact Section */
  .contact-section {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-card {
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-sub {
    font-family: var(--font-display);
    color: var(--accent-cyan);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .contact-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 1.5rem;
  }

  .contact-desc {
    max-width: 580px;
    margin-bottom: 2.5rem;
  }

  .contact-btn {
    padding: 1rem 3rem;
    font-size: 1.1rem;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    
    .resume-header {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-bottom: 3rem;
    }
    
    .hero-ctas {
      flex-direction: column;
      align-items: stretch;
    }
    
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
