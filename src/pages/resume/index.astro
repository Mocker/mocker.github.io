---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const resumeEntry = await getEntry('resume', 'experience');
const resume = resumeEntry?.data;
---

<BaseLayout
  title="Resume | Ryan Guthrie, Senior Software Engineer & Software Architect"
  description="Ryan Guthrie's experience, technical strengths, and career history across senior software engineering, architecture, cloud infrastructure, and product delivery."
>
  <header class="resume-hero container">
    <div>
      <a class="back-link" href="/">← Portfolio</a>
      <p class="eyebrow">Resume</p>
      <h1>Ryan Guthrie</h1>
      <p class="role">Senior Software Engineer · Software Architect</p>
      <p class="summary">{resume?.summary}</p>
    </div>
    <aside class="contact-card">
      <p>Eugene, Oregon · Remote</p>
      <a href="mailto:ryan@ryanguthrie.com">ryan@ryanguthrie.com</a>
      <a href="https://www.linkedin.com/in/ryanguthrie/" target="_blank" rel="noopener noreferrer">linkedin.com/in/ryanguthrie ↗</a>
      <div class="resume-actions">
        <a class="btn-primary" href="/assets/Ryan_Guthrie_Resume.pdf" target="_blank">Open PDF</a>
        <a class="btn-secondary" href="/assets/Ryan_Guthrie_Resume.pdf" download="Ryan_Guthrie_Resume.pdf">Download</a>
      </div>
    </aside>
  </header>

  <div class="resume-body container">
    <main class="experience-column">
      <section aria-labelledby="experience-title">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">Career history</h2>
        <div class="timeline">
          {resume?.experience.map((job) => (
            <article class="job">
              <header>
                <div>
                  <h3>{job.role}</h3>
                  <p class="company">{job.company}</p>
                </div>
                <div class="job-meta">
                  <p>{job.period}</p>
                  {job.location && <p>{job.location}</p>}
                </div>
              </header>
              <ul>
                {job.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>
    </main>

    <aside class="resume-sidebar">
      <section aria-labelledby="strengths-title">
        <p class="eyebrow">Strengths</p>
        <h2 id="strengths-title">Technical focus</h2>
        <ul class="skill-list">
          {resume?.skills.featured?.map((skill) => <li>{skill}</li>)}
        </ul>
      </section>

      <section aria-labelledby="approach-title">
        <p class="eyebrow">Approach</p>
        <h2 id="approach-title">How I work</h2>
        <div class="approach-list">
          {resume?.philosophy.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="additional-title">
        <p class="eyebrow">Additional tools</p>
        <h2 id="additional-title">Working range</h2>
        <p class="compact-list">{resume?.skills.languages.join(' · ')}</p>
        <p class="compact-list">{resume?.skills.webAndEdge.join(' · ')}</p>
      </section>

      <section aria-labelledby="languages-title">
        <p class="eyebrow">Languages</p>
        <h2 id="languages-title">Communication</h2>
        <ul class="language-list">
          {resume?.languages.map((language) => (
            <li><strong>{language.name}</strong><span>{language.proficiency}</span></li>
          ))}
        </ul>
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  .resume-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.55fr);
    gap: clamp(2.5rem, 8vw, 7rem);
    padding-block: clamp(4rem, 8vw, 6.5rem);
    border-bottom: 1px solid var(--line);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2.5rem;
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 700;
  }

  h1 {
    margin-top: 0.7rem;
    font-size: clamp(3.1rem, 7vw, 5.8rem);
    letter-spacing: -0.055em;
  }

  .role {
    margin-top: 0.5rem;
    color: var(--accent);
    font-size: clamp(1.15rem, 2.3vw, 1.45rem);
    font-weight: 700;
  }

  .summary {
    max-width: 760px;
    margin-top: 1.6rem;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .contact-card {
    align-self: end;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-left: 1.5rem;
    border-left: 1px solid var(--line-strong);
  }

  .contact-card p,
  .contact-card a:not(.btn-primary):not(.btn-secondary) {
    font-size: 0.9rem;
  }

  .resume-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .resume-body {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(260px, 0.62fr);
    gap: clamp(3rem, 8vw, 7rem);
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .experience-column h2,
  .resume-sidebar h2 {
    margin-top: 0.55rem;
    font-size: 2rem;
    letter-spacing: -0.03em;
  }

  .timeline {
    margin-top: 2.25rem;
  }

  .job {
    padding-block: 2rem;
    border-top: 1px solid var(--line);
  }

  .job header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(190px, auto);
    gap: 1.5rem;
  }

  .job h3 {
    font-size: 1.28rem;
  }

  .company {
    margin-top: 0.25rem;
    color: var(--accent);
    font-size: 0.96rem;
    font-weight: 700;
  }

  .job-meta {
    text-align: right;
  }

  .job-meta p {
    color: var(--muted);
    font-size: 0.8rem;
  }

  .job ul {
    display: grid;
    gap: 0.7rem;
    margin-top: 1.25rem;
    padding-left: 1.2rem;
    color: var(--text-soft);
  }

  .job li {
    padding-left: 0.25rem;
    font-size: 0.94rem;
  }

  .job li::marker {
    color: var(--accent);
  }

  .resume-sidebar {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .skill-list,
  .language-list {
    margin-top: 1.4rem;
    padding: 0;
    list-style: none;
  }

  .skill-list li {
    padding-block: 0.65rem;
    border-top: 1px solid var(--line);
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .approach-list {
    display: grid;
    gap: 1.35rem;
    margin-top: 1.5rem;
  }

  .approach-list h3 {
    font-size: 1rem;
  }

  .approach-list p,
  .compact-list {
    margin-top: 0.45rem;
    font-size: 0.87rem;
    line-height: 1.65;
  }

  .compact-list + .compact-list {
    margin-top: 1rem;
  }

  .language-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.7rem;
    border-top: 1px solid var(--line);
    color: var(--text-soft);
    font-size: 0.86rem;
  }

  .language-list span {
    color: var(--muted);
    text-align: right;
  }

  @media (max-width: 850px) {
    .resume-hero,
    .resume-body {
      grid-template-columns: 1fr;
    }

    .contact-card {
      align-self: auto;
    }
  }

  @media (max-width: 560px) {
    .job header {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .job-meta {
      text-align: left;
    }
  }
</style>
