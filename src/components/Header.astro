---
const isResume = Astro.url.pathname.startsWith('/resume');
---

<header class="site-header">
  <div class="container nav-container">
    <a href="/" class="identity" aria-label="Ryan Guthrie, home">
      <img src="/assets/modern_pisces_logo.png" alt="" width="34" height="34" />
      <span>Ryan Guthrie</span>
    </a>

    <nav aria-label="Primary navigation">
      <a href="/#about">About</a>
      <a href="/#work">Work</a>
      <a href="/resume" aria-current={isResume ? 'page' : undefined}>Resume</a>
      <a href="/#contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    min-height: var(--nav-height);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--line);
    background: rgba(10, 16, 23, 0.9);
    backdrop-filter: blur(18px);
  }

  .nav-container,
  .identity,
  nav {
    display: flex;
    align-items: center;
  }

  .nav-container {
    justify-content: space-between;
    gap: 2rem;
  }

  .identity {
    gap: 0.7rem;
    color: var(--text);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 750;
    letter-spacing: -0.015em;
    white-space: nowrap;
  }

  .identity img {
    border-radius: 50%;
  }

  nav {
    gap: clamp(0.75rem, 2.8vw, 2rem);
  }

  nav a {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    color: var(--text-soft);
    font-size: 0.91rem;
    font-weight: 650;
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--accent-strong);
  }

  @media (max-width: 620px) {
    .site-header {
      position: static;
      padding-block: 0.75rem;
    }

    .nav-container {
      flex-wrap: wrap;
      gap: 0.25rem 1rem;
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.5rem;
    }
  }
</style>
