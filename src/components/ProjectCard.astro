---
interface Props {
  title: string;
  description: string;
  tags: string[];
  kind: string;
  status: string;
  timeframe?: string;
}

const { title, description, tags, kind, status, timeframe } = Astro.props;
---

<article class="project-card">
  <div class="project-meta">
    <span>{kind}</span>
    <span aria-hidden="true">/</span>
    <span>{status}</span>
  </div>
  <h3>{title}</h3>
  {timeframe && <p class="timeframe">{timeframe}</p>}
  <p class="description">{description}</p>
  <ul class="tags" aria-label={`${title} technologies and focus areas`}>
    {tags.map((tag) => <li>{tag}</li>)}
  </ul>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: clamp(1.35rem, 3vw, 2rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: linear-gradient(150deg, rgba(22, 34, 46, 0.82), rgba(12, 20, 29, 0.94));
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h3 {
    margin-top: 1.05rem;
    font-size: 1.55rem;
    letter-spacing: -0.02em;
  }

  .timeframe {
    margin-top: 0.45rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .description {
    margin-top: 1rem;
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding: 1.4rem 0 0;
    list-style: none;
  }

  .tags li {
    padding: 0.28rem 0.65rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-soft);
    font-size: 0.76rem;
  }
</style>
