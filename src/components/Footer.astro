---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-content">
    <p>© {currentYear} Ryan Guthrie. Built with Astro and deployed on Cloudflare.</p>
    <nav aria-label="Social links">
      <a href="mailto:ryan@ryanguthrie.com">Email</a>
      <a href="https://www.linkedin.com/in/ryanguthrie/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://github.com/Mocker" target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding-block: 2.25rem;
  }

  .footer-content,
  nav {
    display: flex;
    align-items: center;
  }

  .footer-content {
    justify-content: space-between;
    gap: 1.5rem;
  }

  p,
  a {
    font-size: 0.88rem;
  }

  p {
    color: var(--muted);
  }

  nav {
    gap: 1.25rem;
  }

  nav a {
    color: var(--text-soft);
    font-weight: 650;
  }

  @media (max-width: 640px) {
    .footer-content {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
